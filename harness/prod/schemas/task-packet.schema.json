{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPacket",
  "type": "object",
  "required": ["project_id", "state", "request"],
  "properties": {
    "project_id": { "type": "string" },
    "state": { "type": "string" },
    "request": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
