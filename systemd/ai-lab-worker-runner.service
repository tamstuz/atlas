[Unit]
Description=AI Lab Worker Runner
After=network-online.target ai-lab-orchestrator.service
Wants=network-online.target

[Service]
Type=simple
User=ai-lab
Group=ai-lab
WorkingDirectory=/srv/ai-lab
EnvironmentFile=/srv/ai-lab/.env
ExecStart=/bin/sh -c 'while true; do sleep 300; done'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
